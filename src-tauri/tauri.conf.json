{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ipharma",
  "version": "0.1.0",
  "identifier": "com.mridasoft.ipharma",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "iPharma",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  },
  "plugins": {
    "updater": {
      "pubkey": "__TAURI_UPDATER_PUBKEY__",
      "endpoints": ["__TAURI_UPDATER_ENDPOINT__"],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
